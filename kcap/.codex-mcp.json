{
  "mcpServers": {
    "kcap-review": {
      "command": "kcap",
      "args": ["mcp", "review"]
    },
    "kcap-sessions": {
      "command": "kcap",
      "args": ["mcp", "sessions"]
    },
    "kcap-memory": {
      "command": "kcap",
      "args": ["mcp", "memory"],
      "cwd": "${CLAUDE_PROJECT_DIR}"
    }
  }
}
